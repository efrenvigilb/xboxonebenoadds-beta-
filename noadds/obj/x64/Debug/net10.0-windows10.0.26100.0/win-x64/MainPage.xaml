<Page
    x:Class="noadds.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:noadds"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:ConnectionId='2' x:Name="RootLayout" RowSpacing="12" Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:ConnectionId='3'
            x:Name="TitleText"
            Text="NoAdds YouTube"
            FontSize="24"
            FontWeight="SemiBold" />

        <Grid x:ConnectionId='4'
            x:Name="NavigationBar"
            Grid.Row="1"
            ColumnSpacing="8"
            Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:ConnectionId='7'
                x:Name="BackButton"
                Grid.Column="0"
                Content="Atras"
                                         />

            <Button x:ConnectionId='8'
                x:Name="ForwardButton"
                Grid.Column="1"
                Content="Adelante"
                                            />

            <Button x:ConnectionId='9'
                Grid.Column="2"
                Content="Inicio"
                                         />

            <Button x:ConnectionId='10'
                Grid.Column="3"
                Content="Recargar"
                                            />

            <Button x:ConnectionId='11'
                Grid.Column="4"
                Content="Extensiones"
                                               />

            <TextBox x:ConnectionId='12'
                x:Name="AddressBar"
                Grid.Column="5"
                PlaceholderText="Escribe una URL o busqueda"
                                             />

            <Button x:ConnectionId='13'
                Grid.Column="6"
                Content="Ir"
                                       />
        </Grid>

        <TextBlock x:ConnectionId='5'
            x:Name="StatusText"
            Grid.Row="2"
            Text="Listo"
            Opacity="0.8" />

        <muxc:WebView2 x:ConnectionId='6'
            x:Name="BrowserView"
            Grid.Row="3"
            Margin="0,8,0,0"
                                                               
                                                                  />
    </Grid>
</Page>

